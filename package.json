{
  "name": "project_management_capm",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4",
    "@cap-js/postgres": "^2",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      }
    },
    "[production]": {
      "requires": {
        "db": {
          "kind": "postgres",
          "schema_evolution": "force",
          "pool": {
            "max": 5,
            "acquireTimeoutMillis": 30000
          }
        },
        "auth": {
          "kind": "mocked"
        }
      }
    }
  }
}
