<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout">
    <Dialog id="CreateProjectDialog" title="{= ${/editingProjectId} ? 'Edit Project' : 'Define New Project' }" contentWidth="480px">
        <content>
            <VBox class="sapUiSmallMargin">
                
                <Label text="Project Name" required="true" class="customLabel"/>
                <Input value="{/newProject/name}" placeholder="Enter project name..." class="customInput sapUiSmallMarginBottom" />
                
                <HBox alignItems="Baseline" class="sapUiTinyMarginBottom">
                    <Label text="Total Budget ($)" class="customLabel"/>
                    <Text text="(Optional - Auto Calculated if left blank)" class="lightText textXs sapUiTinyMarginBegin" />
                </HBox>
                <Input value="{/newProject/budget}" type="Number" placeholder="Auto Calculated from Actuals..." class="customInput sapUiSmallMarginBottom" />

                <layout:Grid defaultSpan="L6 M6 S6" class="sapUiNoMarginTop">
                    <VBox>
                        <Label text="Start Date" required="true" class="customLabel"/>
                        <DatePicker value="{/newProject/startDate}" valueFormat="yyyy-MM-dd" displayFormat="MM/dd/yyyy" placeholder="mm/dd/yyyy" class="customInput w-full" />
                    </VBox>
                    <VBox>
                        <Label text="End Date" required="true" class="customLabel"/>
                        <DatePicker value="{/newProject/endDate}" valueFormat="yyyy-MM-dd" displayFormat="MM/dd/yyyy" placeholder="mm/dd/yyyy" class="customInput w-full" />
                    </VBox>
                </layout:Grid>

                <VBox class="customDivider sapUiSmallMarginTopBottom" width="100%"></VBox>

                <HBox justifyContent="SpaceBetween" alignItems="Center">
                    <Label text="Required Resources" class="customLabel"/>
                    <HBox alignItems="Center">
                        <Input value="{/newCustomRole}" placeholder="New Role..." width="6.5rem" class="customInput textXsInput sapUiTinyMarginEnd" />
                        <Button text="+" press="onAddCustomRole" class="darkGreyBtn sapUiTinyMarginEnd" />
                        <Button text="+ Add Req" press="onAddRoleToProject" class="lightBlueBtn" />
                    </HBox>
                </HBox>

                <Text text="No specific resource roles defined." visible="{= ${/newProject/requiredRoles}.length === 0 }" class="lightText italicText sapUiSmallMarginTop" />

                <VBox items="{/newProject/requiredRoles}" class="sapUiTinyMarginTop">
                    <items>
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom" width="100%">
                            <ComboBox selectedKey="{role}" items="{path: '/availableRoles', templateShareable: true}" class="customInput sapUiTinyMarginEnd" width="100%">
                                <core:Item key="{}" text="{}" />
                            </ComboBox>
                            <Input value="{count}" type="Number" placeholder="Qty" class="customInput sapUiTinyMarginEnd" width="4rem" />
                            <Button icon="sap-icon://delete" press="onDeleteRoleFromProject" type="Transparent" class="actionDelete" tooltip="Remove role" />
                        </HBox>
                    </items>
                </VBox>

            </VBox>
        </content>
        <beginButton><Button text="{= ${/editingProjectId} ? 'Update' : 'Save' }" press="onSaveProject" class="customPrimaryBtn" /></beginButton>
        <endButton><Button text="Cancel" press="onCloseDialog" type="Transparent" class="customCancelBtn" /></endButton>
    </Dialog>
</core:FragmentDefinition>