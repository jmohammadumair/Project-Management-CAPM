    "ProjectManagerService.Analytics_Cost_Consumption": {
      "kind": "entity",
      "@readonly": true,
      "query": {
        "SELECT": {
          "from": {
            "ref": [
              "ProjectManagerService.Allocations"
            ]
          },
          "columns": [
            {
              "key": true,
              "ref": [
                "project",
                "ID"
              ],
              "as": "projectId"
            },
            {
              "ref": [
                "project",
                "name"
              ],
              "as": "projectName"
            },
            {
              "ref": [
                "project",
                "budget"
              ],
              "as": "projectBudget"
            },
            {
              "xpr": [
                {
                  "func": "sum",
                  "args": [
                    {
                      "xpr": [
                        {
                          "ref": [
                            "hours"
                          ]
                        },
                        "*",
                        {
                          "ref": [
                            "resource",
                            "hourlyRate"
                          ]
                        }
                      ]
                    }
                  ],
                  "cast": {
                    "type": "cds.Decimal",
                    "precision": 15,
                    "scale": 2
                  }
                }
              ],
              "as": "consumedCost"
            }
          ],
          "groupBy": [
            {
              "ref": [
                "project",
