        "endDate": {
          "type": "cds.Date"
        },
        "requiredRoles": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "my.projectmanager.ProjectRoles",
          "on": [
            {
              "ref": [
                "requiredRoles",
                "project"
